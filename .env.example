# Backend
PYTHON_ENV=development
# Task 1 spec default; currently known to 404 live, so override if a working ADSB.lol endpoint is available.
ADSBLOL_API_URL=https://api.adsb.lol/aircraft/json
ADSBLOL_REFRESH_SECONDS=30
# aisstream.io — paste your free API key from https://aisstream.io/
AISSTREAM_API_KEY=your_aisstream_api_key_here
AISSTREAM_BATCH_INTERVAL_SECONDS=30

# ACLED — free registration at https://acleddata.com/register
ACLED_EMAIL=your_email@domain.com
ACLED_PASSWORD=your_acled_password

# Refresh intervals (defaults shown)
GDELT_REFRESH_SECONDS=900
ACLED_REFRESH_SECONDS=86400

# Frontend
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

