# ── Backend ──────────────────────────────────────────────────────────────
PYTHON_ENV=development

# ADS-B data source — adsb.lol API (global aircraft tracking)
# Task 1 spec default; currently known to 404 live, so override if a working endpoint is available.
ADSBLOL_API_URL=https://api.adsb.lol/aircraft/json
ADSBLOL_REFRESH_SECONDS=30
ADSB_REFRESH_SECONDS=30

# aisstream.io — paste your free API key from https://aisstream.io/
# Required for live maritime vessel tracking
AISSTREAM_API_KEY=your_aisstream_api_key_here
AISSTREAM_BATCH_INTERVAL_SECONDS=30
AIS_REFRESH_SECONDS=60

# OpenSky Network OAuth2 — FREE registration at https://opensky-network.org/register
# Create API client at: https://opensky-network.org/my-opensky/account
# Required: client_id and client_secret (NOT your login password)
# Without this, OpenSky uses strict anonymous rate limits (~400 credits/day)
# With auth: 4,000–8,000 credits/day, 5-second resolution vs 10-second anonymous
OPENSKY_CLIENT_ID=your_opensky_client_id_here
OPENSKY_CLIENT_SECRET=your_opensky_client_secret_here

# GDELT — World event monitoring (no auth required)
GDELT_REFRESH_SECONDS=900

# ACLED — Conflict zone data — FREE registration at https://acleddata.com/register
ACLED_EMAIL=your_acled_email_here
ACLED_PASSWORD=your_acled_password_here
ACLED_REFRESH_SECONDS=86400

# ── Frontend ─────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# ── Docker Compose internal proxies ──────────────────────────────────────
# These are used inside docker-compose.yml for inter-container networking.
# You typically don't need to change these for local Docker usage.
VITE_PROXY_TARGET=http://backend:8000
VITE_WS_PROXY_TARGET=ws://backend:8000